@model IMS.WEB.ViewModels.StockHistoryViewModel

<div class="d-flex justify-content-between align-items-center mb-3">

    <h3>Transaction History</h3>

</div>

<div class="mb-3">

    <a href="/Stock/Index"
       class="btn btn-secondary">

        ← Back to Inventory

    </a>

</div>

<form method="get"
      class="mb-3 d-flex gap-2">

    <input type="text"
           name="search"
           value="@Model.Search"
           class="form-control"
           placeholder="Search by product..." />

    <button class="btn btn-primary">
        Search
    </button>

    <a href="/Stock/History"
       class="btn btn-secondary">
        Reset
    </a>

</form>

<div class="table-responsive">

    <table  class="table table-bordered table-edit-grid">

        <thead>

            <tr>
                <th>Product</th>
                <th>Type</th>
                <th>Quantity</th>
                <th>Previous</th>
                <th>New</th>
                <th>Remarks</th>
                <th>Date</th>
                <th>User</th>
            </tr>

        </thead>

        <tbody>

            @if (Model.Transactions.Any())
            {
                @foreach (var item in Model.Transactions)
                {
                    <tr>

                        <td>
                            @item.ProductName
                        </td>

                        <td>

                            @if (item.TransactionType == "IN")
                            {
                                <span class="badge bg-success">
                                    IN
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    OUT
                                </span>
                            }

                        </td>

                        <td>
                            @item.Quantity
                        </td>

                        <td>
                            @item.PreviousQuantity
                        </td>

                        <td>
                            @item.NewQuantity
                        </td>

                        <td>
                            @item.Remarks
                        </td>

                        <td>
                            @item.CreatedAt
                        </td>

                        <td>
                            @item.CreatedBy
                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>

                    <td colspan="8"
                        class="text-center text-muted">

                        No transaction history found.

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<nav>

    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">

                <a class="page-link"
                   href="/Stock/History?page=@i&pageSize=@Model.PageSize&search=@Model.Search">

                    @i

                </a>

            </li>
        }

    </ul>

</nav>