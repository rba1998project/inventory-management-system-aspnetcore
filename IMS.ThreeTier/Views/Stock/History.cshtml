@model IMS.WEB.ViewModels.StockHistoryViewModel

<div class="d-flex justify-content-between align-items-center">
    <h3>Transaction History</h3>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">

    <a href="/Stock/Index"
       class="btn btn-secondary">
        ← Back to Inventory
    </a>

    <div class="d-flex gap-2">
        <a href="/Stock/ExportExcel?search=@Model.Search&transactionType=@Model.TransactionType&createdBy=@Model.CreatedBy"
           class="btn btn-success">
            Export Excel
        </a>

        <a href="/Stock/ExportPdf?search=@Model.Search&transactionType=@Model.TransactionType&createdBy=@Model.CreatedBy"
           class="btn btn-danger">
            Export PDF
        </a>
    </div>

</div>

<form method="get"
      class="mb-3">

    <div class="row g-2">
        <div class="col-md-3">
            <input type="text"
                   name="search"
                   value="@Model.Search"
                   class="form-control"
                   placeholder="Search by product..." />
        </div>

        <div class="col-md-2">
            <select name="transactionType" class="form-select">
                <option value="">-- All Types --</option>
                <option value="IN" selected="@(Model.TransactionType == "IN")">IN</option>
                <option value="OUT" selected="@(Model.TransactionType == "OUT")">OUT</option>
                <option value="ADJUSTMENT" selected="@(Model.TransactionType == "ADJUSTMENT")">ADJUSTMENT</option>
            </select>
        </div>

        <div class="col-md-2">
            <select name="createdBy" class="form-select">
                <option value="">-- All Users --</option>
                @foreach (var user in Model.CreatedByUsers)
                {
                    <option value="@user" selected="@(Model.CreatedBy == user)">@user</option>
                }
            </select>
        </div>

        <div class="col-md-5">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
                <a href="/Stock/History" class="btn btn-secondary">Reset</a>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">

    <table class="table table-bordered table-edit-grid">

        <thead>

            <tr>
                <th>Product</th>
                <th>Type</th>
                <th>Quantity</th>
                <th>Previous</th>
                <th>New</th>
                <th>Remarks</th>
                <th>Date</th>
                <th>User</th>
            </tr>

        </thead>

        <tbody>

            @if (Model.Transactions.Any())
            {
                @foreach (var item in Model.Transactions)
                {
                    <tr>

                        <td>@item.ProductName</td>

                        <td>

                            @if (item.TransactionType == "IN")
                            {
                                <span class="badge bg-success">
                                    IN
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    OUT
                                </span>
                            }

                        </td>

                        <td>@item.Quantity</td>

                        <td>@item.PreviousQuantity</td>

                        <td>@item.NewQuantity</td>

                        <td>@item.Remarks</td>

                        <td>@(item.CreatedAt.ToUiDate())</td>

                        <td>@item.CreatedBy</td>

                    </tr>
                }
            }
            else
            {
                <tr>

                    <td colspan="8"
                        class="text-center text-muted">

                        No transaction history found.

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<nav>

    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">

                <a class="page-link"
                   href="/Stock/History?page=@i&pageSize=@Model.PageSize&search=@Model.Search&transactionType=@Model.TransactionType&createdBy=@Model.CreatedBy">

                    @i

                </a>

            </li>
        }

    </ul>

</nav>