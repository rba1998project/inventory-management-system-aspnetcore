<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - IMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    @*added for icons*@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    IMS
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Category"
                                   asp-action="Index">
                                    Categories
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Supplier"
                                   asp-action="Index">
                                    Suppliers
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Product"
                                   asp-action="Index">
                                    Products
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Stock"
                                   asp-action="Index">
                                    Inventory
                                </a>
                            </li>


                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (ViewData["HideNavbarAuth"] == null || !(bool)ViewData["HideNavbarAuth"]!)
                        {
                            @if (User.Identity!.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <span class="nav-link text-light">
                                        Hello @User.Identity.Name
                                    </span>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Auth"
                                       asp-action="Logout">
                                        Logout
                                    </a>
                                </li>
                            }
                            else
                            {

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Auth"
                                       asp-action="Login">
                                        Login
                                    </a>
                                </li>

                            }
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container py-3">
            &copy; @DateTime.UtcNow.Year - IMS by Rifat Bin Aziz
        </div>
    </footer>

    @* Global feedback modal (used by showModal in site.js) *@
    <partial name="_MessageModal" />

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>

    @*added to load custom JavaScript exclusively for site help*@ 
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>