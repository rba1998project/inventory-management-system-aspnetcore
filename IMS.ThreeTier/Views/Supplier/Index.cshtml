@using IMS.WEB.ViewModels
@model SupplierListViewModel

<div class="d-flex justify-content-between align-items-center mb-3">

    <h3>Supplier List</h3>

    <button class="btn btn-primary" id="btnCreateSupplier">
        + Create Supplier
    </button>

</div>

<form method="get" class="mb-3 d-flex gap-2">

    <input type="text"
           name="search"
           value="@Model.Search"
           class="form-control"
           placeholder="Search suppliers..." />

    <button type="submit" class="btn btn-primary">
        Search
    </button>

    <a href="/Supplier/Index" class="btn btn-secondary">
        Reset
    </a>

</form>

<div class="table-responsive">

    <table class="table table-bordered table-edit-grid" id="supplierTable">

        <thead>
            <tr>
                <th>Name</th>
                <th>Contact Person</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Products</th>

                @if (User.IsInRole("Admin"))
                {
                    <th>Created At</th>
                    <th>Created By</th>
                    <th>Last Updated</th>
                    <th>Updated By</th>
                }

                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.Suppliers)
            {
                <tr data-id="@item.Id">

                    <td class="editable-cell" contenteditable="true">
                        @item.Name
                    </td>

                    <td class="editable-cell" contenteditable="true">
                        @item.ContactPerson
                    </td>

                    <td class="editable-cell" contenteditable="true" data-type="email">
                        @item.Email
                    </td>

                    <td class="editable-cell" contenteditable="true" data-type="phone">
                        @item.Phone
                    </td>

                    <td class="editable-cell" contenteditable="true">
                        @item.Address
                    </td>

                    <td>
                        @if (item.ProductCount > 0)
                        {
                            <a href="#"
                               class="productCountLink text-primary"
                               data-id="@item.Id">
                                @item.ProductCount
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">0</span>
                        }
                    </td>

                    @if (User.IsInRole("Admin"))
                    {
                        <td class="audit-cell">@item.CreatedAt</td>
                        <td class="audit-cell">@item.CreatedBy</td>
                        <td class="audit-cell">@item.LastModifiedAt</td>
                        <td class="audit-cell">@item.LastModifiedBy</td>
                    }

                    <td class="actions-cell">

                        <div class="action-buttons">

                            <button type="button"
                                    class="btn btn-success btn-sm saveBtn">
                                Update
                            </button>

                            <button type="button"
                                    class="btn btn-danger btn-sm deleteBtn">
                                Delete
                            </button>

                        </div>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<nav>
    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">

                <a class="page-link"
                   href="/Supplier/Index?page=@i&pageSize=@Model.PageSize&search=@Model.Search">
                    @i
                </a>

            </li>
        }

    </ul>
</nav>

<div class="modal fade" id="createSupplierModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="createSupplierContent"></div>
    </div>
</div>

<div class="modal fade" id="deleteSupplierModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title text-danger">
                    Confirm Delete
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p>
                    Are you sure you want to delete
                    <strong id="deleteSupplierName"></strong>?
                </p>

                <p class="text-danger">
                    Deleting this supplier will also delete all related products.
                </p>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-danger"
                        id="confirmDeleteBtn">
                    Delete
                </button>

            </div>

        </div>

    </div>

</div>

<div class="modal fade" id="productListModal" tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Products of Supplier
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body" id="productListContent">
            </div>

        </div>

    </div>

</div>

@section Scripts {
<script>

    function showError(msg) {
        showModal("Error", msg);
    }

    function showSuccess(msg) {
        showModal("Success", msg);
    }

    function markDirty(row) {
        row.addClass("cell-dirty");
    }

    // mark row dirty on edit
    $(document).on("input", "td[contenteditable=true]", function () {
        markDirty($(this).closest("tr"));
    });

    // restrict phone typing (live cleanup)
    $(document).on("input", "[data-type='phone']", function () {
        let text = $(this).text();
        text = text.replace(/[^0-9+\-\s]/g, '');
        $(this).text(text);
    });

    $(".saveBtn").click(function () {

        var row = $(this).closest("tr");

        var email = row.find("[data-type='email']").text().trim();
        var phone = row.find("[data-type='phone']").text().trim();

        // SAFE EMAIL regex (important: no syntax issues in Razor)
        var emailRegex = new RegExp("^[^\\s@@]+@@[^\\s@@]+\\.[^\\s@@]+$");

        // PHONE regex
        var phoneRegex = new RegExp("^[0-9+\\-\\s]{7,15}$");

        if (!emailRegex.test(email)) {
            showError("Invalid email format");
            return;
        }

        if (!phoneRegex.test(phone)) {
            showError("Invalid phone number");
            return;
        }

        var data = {
            Id: row.data("id"),
            Name: row.find("td:eq(0)").text().trim(),
            ContactPerson: row.find("td:eq(1)").text().trim(),
            Email: email,
            Phone: phone,
            Address: row.find("td:eq(4)").text().trim()
        };

        $.post("/Supplier/Edit", data, function (res) {

            if (res.success) {
                row.removeClass("cell-dirty");
                showSuccess("Supplier updated successfully");
            } else {
                showError(res.message || "Update failed");
            }

        }).fail(function () {
            showError("Server error");
        });
    });

    let deleteId = 0;
    let deleteRow = null;

    $(".deleteBtn").click(function () {

        deleteRow = $(this).closest("tr");
        deleteId = deleteRow.data("id");

        $("#deleteSupplierName").text(
            deleteRow.find("td:eq(0)").text().trim()
        );

        new bootstrap.Modal(
            document.getElementById('deleteSupplierModal')
        ).show();
    });

    $("#confirmDeleteBtn").click(function () {

        $.post("/Supplier/Delete", { id: deleteId }, function (res) {

            $("#deleteSupplierModal").modal("hide");

            if (res.success) {
                deleteRow.remove();
                showSuccess("Supplier deleted successfully");
            } else {
                showError("Delete failed");
            }
        });
    });

    $("#btnCreateSupplier").click(function () {

        $.get("/Supplier/Create", function (data) {

            $("#createSupplierContent").html(data);

            new bootstrap.Modal(
                document.getElementById('createSupplierModal')
            ).show();
        });
    });

    $(document).on("submit", "#createSupplierForm", function (e) {

        e.preventDefault();

        $.ajax({
            url: "/Supplier/Create",
            type: "POST",
            data: $(this).serialize(),

            success: function () {

                $("#createSupplierModal").modal("hide");

                showSuccess("Supplier created successfully");

                setTimeout(function () {
                    location.reload();
                }, 800);
            },

            error: function () {
                showError("Failed to create supplier");
            }
        });
    });

    $(document).on("click", ".productCountLink", function (e) {

        e.preventDefault();

        var supplierId = $(this).data("id");

        $.get("/Supplier/GetProducts", { id: supplierId }, function (data) {

            $("#productListContent").html(data);

            new bootstrap.Modal(
                document.getElementById('productListModal')
            ).show();
        });
    });

</script>
}