@using IMS.WEB.ViewModels
@*commented and added for search and pagination functionality*@ 
@*@model IEnumerable<CategoryViewModel>*@
@model CategoryListViewModel


<div class="d-flex justify-content-between align-items-center mb-3">

    <h3>Category List</h3>

    <button class="btn btn-primary"
            id="btnCreateCategory">
        + Create Category
    </button>

</div>

<form method="get" class="mb-3 d-flex gap-2">

    <input type="text"
           name="search"
           value="@Model.Search"
           class="form-control"
           placeholder="Search categories..." />

    <button type="submit" class="btn btn-primary">
        Search
    </button>

    <a href="/Category/Index" class="btn btn-secondary">
        Reset
    </a>

</form>

<table class="table table-bordered" id="categoryTable">
    <thead>
        <tr>
            <th>
                Name
                <i class="bi bi-pencil-square text-muted ms-1"></i>
            </th>

            <th>
                Description
                <i class="bi bi-pencil-square text-muted ms-1"></i>
            </th>
            <th>Products</th>

            @if (User.IsInRole("Admin"))
            {
                <th>Created At</th>
                <th>Created By</th>
                <th>Last Updated</th>
                <th>Updated By</th>
            }
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @*commented and added for search and pagination functionality*@
        @*@foreach (var item in Model)*@
        @foreach (var item in Model.Categories)
        {
            <tr data-id="@item.Id">
                <td contenteditable="true">@item.Name</td>
                <td contenteditable="true">@item.Description</td>
                <td>
                    @if (item.ProductCount > 0)
                    {
                        <a href="#"
                           class="productCountLink text-primary"
                           data-id="@item.Id">
                            @item.ProductCount
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">0</span>
                    }
                </td>

                @if (User.IsInRole("Admin"))
                {
                    <td>@item.CreatedAt</td>
                    <td>@item.CreatedBy</td>
                    <td>@item.LastModifiedAt</td>
                    <td>@item.LastModifiedBy</td>
                }
                <td>
                    <div class="d-flex gap-2 w-100">
                        <button class="btn btn-success btn-sm flex-fill saveBtn">
                            Update
                        </button>

                        <button class="btn btn-danger btn-sm flex-fill deleteBtn">
                            Delete
                        </button>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">

                <a class="page-link"
                   href="/Category/Index?page=@i&pageSize=@Model.PageSize&search=@Model.Search">
                    @i
                </a>

            </li>
        }

    </ul>
</nav>

<div class="modal fade" id="createCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="createCategoryContent">
        </div>
    </div>
</div>

<div class="modal fade" id="deleteCategoryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    Confirm Delete
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <p>
                    Are you sure you want to delete
                    <strong id="deleteCategoryName"></strong>?
                </p>

                <p class="text-danger">
                    Deleting this category will also permanently delete all associated products.
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-danger"
                        id="confirmDeleteBtn">
                    Delete
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="productListModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Products in Category</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body" id="productListContent">
                <!-- loaded dynamically -->
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on("input", "td[contenteditable=true]", function () {
            $(this).closest("tr").addClass("table-warning"); // row changed
        });

        $(".saveBtn").click(function () {

            var row = $(this).closest("tr");

            var data = {
                Id: row.data("id"),
                Name: row.find("td:eq(0)").text(),
                Description: row.find("td:eq(1)").text()
            };

            $.post("/Category/Edit", data, function (res) {
                if (res.success) {
                    row.removeClass("table-warning");
                    showModal("Success", "Category updated successfully");
                } else {
                    showModal("Error", "Update failed");
                }
            });
        });

        let deleteId = 0;
        let deleteRow = null;

        $(".deleteBtn").click(function () {

            deleteRow = $(this).closest("tr");
            deleteId = deleteRow.data("id");

            let categoryName = deleteRow.find("td:eq(0)").text();

            $("#deleteCategoryName").text(categoryName);

            var modal = new bootstrap.Modal(
                document.getElementById('deleteCategoryModal')
            );

            modal.show();
        });

        $("#confirmDeleteBtn").click(function () {

            $.post("/Category/Delete", { id: deleteId }, function (res) {

                $("#deleteCategoryModal").modal("hide");

                if (res.success) {
                    showModal("Success", "Category deleted successfully");
                    deleteRow.remove();
                } else {
                    showModal("Error", "Category deleted failed");
                }

                

                
            });

        });
    </script>


    <script>

        $("#btnCreateCategory").click(function () {

            $.get("/Category/Create", function (data) {

                $("#createCategoryContent").html(data);

                var modal = new bootstrap.Modal(
                    document.getElementById('createCategoryModal')
                );

                modal.show();
            });
        });


        $(document).on("submit", "#createCategoryForm", function (e) {

            e.preventDefault();

            $.ajax({
                url: "/Category/Create",
                type: "POST",
                data: $(this).serialize(),

                success: function () {

                    $("#createCategoryModal").modal("hide");

                    showModal(
                        "Success",
                        "Category created successfully"
                    );

                    setTimeout(function () {
                        location.reload();
                    }, 1000);
                },

                error: function () {

                    showModal(
                        "Error",
                        "Failed to create category"
                    );
                }
            });

        });

    </script>

    <script>
          $(document).on("click", ".productCountLink", function (e) {
            e.preventDefault();

            var categoryId = $(this).data("id");

            $.get("/Category/GetProducts", { id: categoryId }, function (data) {

                $("#productListContent").html(data);

                var modal = new bootstrap.Modal(
                    document.getElementById('productListModal')
                );

                modal.show();
            });
        });
    </script>
}