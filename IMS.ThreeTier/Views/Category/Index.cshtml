@model IMS.WEB.ViewModels.CategoryListViewModel

<div class="d-flex justify-content-between align-items-center mb-3">

    <h3>Category List</h3>

    <button class="btn btn-primary" id="btnCreateCategory">
        + Create Category
    </button>

</div>

<form method="get" class="mb-3 d-flex gap-2">

    <input type="text"
           name="search"
           value="@Model.Search"
           class="form-control"
           placeholder="Search categories..." />

    <button type="submit" class="btn btn-primary">
        Search
    </button>

    <a href="/Category/Index" class="btn btn-secondary">
        Reset
    </a>

</form>

<div class="table-responsive">

    <table class="table table-bordered table-edit-grid" id="categoryTable">

        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Products</th>

                @if (User.IsInRole("Admin"))
                {
                    <th>Created At</th>
                    <th>Created By</th>
                    <th>Last Updated</th>
                    <th>Updated By</th>
                }

                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.Categories)
            {
                <tr data-id="@item.Id">

                    <td class="editable-cell" contenteditable="true">
                        @item.Name
                    </td>

                    <td class="editable-cell" contenteditable="true">
                        @item.Description
                    </td>

                    <td>
                        @if (item.ProductCount > 0)
                        {
                            <a href="#"
                               class="productCountLink text-primary"
                               data-id="@item.Id">
                                @item.ProductCount
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">0</span>
                        }
                    </td>

                    @if (User.IsInRole("Admin"))
                    {
                        <td class="audit-cell">@(item.CreatedAt.ToUiDate())</td>
                        <td class="audit-cell">@item.CreatedBy</td>
                        <td class="audit-cell">@(item.LastModifiedAt.ToUiDate())</td>
                        <td class="audit-cell">@item.LastModifiedBy</td>
                    }

                    <td class="actions-cell">

                        <div class="action-buttons">

                            <button type="button"
                                    class="btn btn-success btn-sm saveBtn">
                                Update
                            </button>

                            <button type="button"
                                    class="btn btn-danger btn-sm deleteBtn">
                                Delete
                            </button>

                        </div>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<nav>
    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">

                <a class="page-link"
                   href="/Category/Index?page=@i&pageSize=@Model.PageSize&search=@Model.Search">
                    @i
                </a>

            </li>
        }

    </ul>
</nav>

<div class="modal fade" id="createCategoryModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content" id="createCategoryContent">
        </div>

    </div>

</div>

<div class="modal fade" id="deleteCategoryModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title text-danger">
                    Confirm Delete
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p>
                    Are you sure you want to delete
                    <strong id="deleteCategoryName"></strong>?
                </p>

                <p class="text-danger">
                    Deleting this category will also delete all related products.
                </p>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-danger"
                        id="confirmDeleteBtn">
                    Delete
                </button>

            </div>

        </div>

    </div>

</div>

<div class="modal fade" id="productListModal" tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">Products in Category</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body" id="productListContent">
            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        function markDirty(row) {
            row.addClass("cell-dirty");
        }

        $(document).on("input", "td[contenteditable=true]", function () {
            markDirty($(this).closest("tr"));
        });

        $(".saveBtn").click(function () {

            var row = $(this).closest("tr");

            var data = {
                Id: row.data("id"),
                Name: row.find("td:eq(0)").text().trim(),
                Description: row.find("td:eq(1)").text().trim()
            };

            $.post("/Category/Edit", data, function (res) {

                if (res.success) {

                    row.removeClass("cell-dirty");

                    showModal("Success", "Category updated successfully");

                } else {
                    showModal("Error", "Update failed");
                }

            }).fail(function () {
                showModal("Error", "Server error");
            });

        });

        let deleteId = 0;
        let deleteRow = null;

        $(".deleteBtn").click(function () {

            deleteRow = $(this).closest("tr");
            deleteId = deleteRow.data("id");

            $("#deleteCategoryName").text(
                deleteRow.find("td:eq(0)").text().trim()
            );

            new bootstrap.Modal(
                document.getElementById('deleteCategoryModal')
            ).show();

        });

        $("#confirmDeleteBtn").click(function () {

            $.post("/Category/Delete", { id: deleteId }, function (res) {

                $("#deleteCategoryModal").modal("hide");

                if (res.success) {
                    deleteRow.remove();
                    showModal("Success", "Category deleted successfully");
                } else {
                    showModal("Error", "Delete failed");
                }

            });

        });

        $("#btnCreateCategory").click(function () {

            $.get("/Category/Create", function (data) {

                $("#createCategoryContent").html(data);

                new bootstrap.Modal(
                    document.getElementById('createCategoryModal')
                ).show();

            });

        });

        $(document).on("submit", "#createCategoryForm", function (e) {

            e.preventDefault();

            $.ajax({
                url: "/Category/Create",
                type: "POST",
                data: $(this).serialize(),

                success: function () {

                    $("#createCategoryModal").modal("hide");

                    showModal("Success", "Category created successfully");

                    setTimeout(function () {
                        location.reload();
                    }, 800);

                },

                error: function () {
                    showModal("Error", "Failed to create category");
                }

            });

        });

        $(document).on("click", ".productCountLink", function (e) {

            e.preventDefault();

            var categoryId = $(this).data("id");

            $.get("/Category/GetProducts", { id: categoryId }, function (data) {

                $("#productListContent").html(data);

                new bootstrap.Modal(
                    document.getElementById('productListModal')
                ).show();

            });

        });

    </script>

}